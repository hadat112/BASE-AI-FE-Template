// Next.js with TypeScript and Tailwind CSS Project Rules
 const projectOverview = [
  "Next.js project using App Router, TypeScript, Tailwind CSS, and shadcn/ui.",
  "Feature-based architecture with shared components.",
];

 const codeStyleGuidelines = [
  "Use TypeScript everywhere.",
  "Keep functions small and single-responsibility.",
  "Prefer minimal diffs over refactors.",
  "Use early returns to reduce nesting.",
  "Avoid magic values; use constants.",
  "Use async/await for async logic.",
  "Follow existing ESLint rules.",
  "Do not reformat code unless required.",
];

 const projectStructure = {
  "src/app/":           "Next.js App Router — routes, layouts, pages ONLY",
  "src/components/ui/": "shadcn/ui primitives ONLY (button, input, modal…) — NO feature components",
  "src/components/common/": "Shared non-UI components (Loading, Empty, ImageWithFallback)",
  "src/components/icons/": "SVG icons as React components + index.tsx barrel export",
  "src/components/layout/": "App shell components (Header, MainLayout, Sidebar…)",
  "src/components/<feature>/": "Feature-specific components — create folder as needed",
  "src/hooks/":         "Custom React hooks — one per file, named use*.ts(x)",
  "src/interfaces/":    "TypeScript interfaces grouped by domain — MUST re-export from index.ts",
  "src/libs/":          "External library configs & wrappers (ApiClient.ts) — NO business logic",
  "src/providers/":     "React context providers — compose in providers/index.tsx",
  "src/services/":      "API service functions — one file per domain, re-export from index.ts",
  "src/styles/":        "Global SCSS (globals.scss, theme.scss)",
  "src/utils/":         "Pure utility functions — re-export from index.ts",
 };

 const filePlacementRules = [
  "New page/route → src/app/ following App Router conventions",
  "New feature component → src/components/<feature>/ComponentName.tsx",
  "New shared component → src/components/common/",
  "New shadcn primitive → src/components/ui/ via npx shadcn-ui@latest add",
  "New icon → add .svg to src/components/icons/, then run: node scripts/update-icons.js && node scripts/generate-icons.js — DO NOT manually edit index.tsx",
  "New hook → src/hooks/use*.ts(x)",
  "New interface → src/interfaces/<domain>.ts, re-export in index.ts",
  "New API service → src/services/<domain>.service.ts, re-export in index.ts",
  "New provider → src/providers/<Name>Provider.tsx, compose in providers/index.tsx",
  "New utility → src/utils/<name>.ts, re-export in index.ts",
 ];

 const fileStructureGuidelines = [
  "Respect the existing folder structure.",
